{
  "expo": {
    "name": "Akiba",
    "slug": "akiba",
    "version": "0.8.0-beta.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "akiba",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.akiba.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "akiba",
              "host": "invite"
            },
            {
              "scheme": "https",
              "host": "akiba.app",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "www.akiba.app",
              "pathPrefix": "/invite"
            }
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/adaptive-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#F7F3EA",
          "dark": {
            "backgroundColor": "#111827"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "23611c3f-8637-4141-87a3-247713d5075f"
      }
    }
  }
}
